{
  "name": "timefrontiers/php-file",
  "description": "TimeFrontiers File — multi-driver file storage, expiring download tokens, and image size constraints",
  "keywords": ["php", "file", "storage", "s3", "upload", "download", "timefrontiers"],
  "homepage": "https://github.com/timefrontiers/php-file",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Ikechukwu Okalia",
      "email": "dev@ikechukwuokalia.com",
      "homepage": "https://ikechukwuokalia.com",
      "role": "developer"
    }
  ],
  "require": {
    "php": ">=8.3",
    "gumlet/php-image-resize": "^2.0",
    "timefrontiers/php-sql-database": "^1.0",
    "timefrontiers/php-database-object": "^1.0",
    "timefrontiers/php-has-errors": "^1.0",
    "timefrontiers/php-pagination": "^1.0",
    "timefrontiers/php-data": "^1.0",
    "timefrontiers/php-validator": "^1.0"
  },
  "require-dev": {},
  "suggest": {
    "aws/aws-sdk-php": "Required when using the S3 storage driver (^3.0)",
    "timefrontiers/php-image": "Advanced image manipulation — crop, watermark, rotate (coming soon)"
  },
  "autoload": {
    "psr-4": {
      "TimeFrontiers\\File\\": "src/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
